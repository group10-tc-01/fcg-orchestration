# terraform.tfvars.example
#
# Copie este arquivo para terraform.tfvars e preencha com seus valores.
# NUNCA commite terraform.tfvars no Git.

# ============================================================================
# Resource Group
# ============================================================================
# resource_group_name = "fiap-fase-04"
# location            = "eastus"

# tags = {
#   environment = "dev"
#   project     = "fiap-fase-04"
#   managed_by  = "terraform"
# }

# ============================================================================
# Azure Container Registry - menor custo viavel
# ============================================================================
# acr_name          = "fcgacrfiap2026"
# acr_sku           = "Basic"
# acr_admin_enabled = false

# ============================================================================
# AKS - Free tier + 1 no barato para demo
# ============================================================================
# aks_cluster_name    = "fcg-aks-fiap2026"
# aks_dns_prefix      = "fcg-aks-fiap2026"
# aks_tier            = "Free"
# aks_node_count      = 1
# aks_node_vm_size    = "Standard_B2ms"
# aks_os_disk_size_gb = 64

# ============================================================================
# Docker
# ============================================================================
# docker_image_tag = "latest"

# ============================================================================
# SQL Server
# ============================================================================
# sql_location = "brazilsouth"
# sql_server_name = "fcg-sql-fiap-2026"
# sql_server_version = "12.0"
# sql_admin_username = "sqladmin"
sql_admin_password = "DEFINA_SUA_SENHA_AQUI"

# SKU dos databases: manter Basic para menor custo.
# sql_database_sku = "Basic"

# ============================================================================
# Runtime secrets
# ============================================================================
jwt_secret_key = "DEFINA_UMA_CHAVE_JWT_FORTE_AQUI"

# Redis, MongoDB e Elasticsearch rodam dentro do AKS.
# redis_connection_string = "redis-service.fcg-system.svc.cluster.local:6379"
# mongodb_connection_string = "mongodb://mongodb-service.fcg-system.svc.cluster.local:27017"
# elasticsearch_uri = "http://elasticsearch-service.fcg-system.svc.cluster.local:9200"

# ============================================================================
# API Management
# ============================================================================
# apim_sku_name = "Developer_1"
# apim_backend_base_url = "https://SEU_INGRESS_PUBLICO"

# ============================================================================
# Azure Functions
# ============================================================================
# functions_service_plan_sku = "Y1"

# ============================================================================
# Firewall do SQL Server - IPs Permitidos
# ============================================================================
# sql_allowed_ips = {
#   "Casa" = "198.51.100.42"
# }
